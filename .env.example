# Jan Aushadhi WordPress store — placeholder secrets (test mode).
# Copy to .env locally; .env is gitignored and NEVER committed.
# WordPress reads payment keys from the plugin's DB settings, not from env —
# these document the key NAMES/format for whoever stands up the store.

# Razorpay (India) — see docs/razorpay-integration.md
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
